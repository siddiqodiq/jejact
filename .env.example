# Copy to .env at the repo root (or set these in Vercel → Project → Settings
# → Environment Variables), then fill in the values.

# --- Strava OAuth -------------------------------------------------------
# Create an app at https://www.strava.com/settings/api
# Authorization Callback Domain: localhost (dev) / your-app.vercel.app (prod)
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# --- Security -----------------------------------------------------------
# Encrypts the session cookie holding your Strava tokens (AES-256-GCM).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-please-32-characters!!"

# --- Optional -----------------------------------------------------------
# Absolute URL override for OAuth redirects. Usually unnecessary — the
# request origin is used, which works on localhost and Vercel.
# APP_URL="https://jejact.vercel.app"
